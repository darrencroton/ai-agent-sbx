# Copy this file to config.env and replace both values with approved Tailscale
# model-server hostnames. Hostnames only: no scheme, path, port, or credentials.
MODEL_HOST_1=macbook.example.ts.net
MODEL_HOST_2=macstudio.example.ts.net

# Additional provider or project download hosts. Each entry is a hostname only.
# chatgpt.com is already included for Codex.
EXTRA_NETWORK_DOMAINS=()

# External project data. Each path must already exist and must be absolute.
# Read-only data is safe for simulation inputs; read/write paths are for results.
READ_ONLY_PATHS=()
READ_WRITE_PATHS=()
